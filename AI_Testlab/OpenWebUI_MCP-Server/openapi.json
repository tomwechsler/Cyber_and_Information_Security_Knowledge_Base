    "/run-nuclei": {
      "post": {
        "operationId": "runNuclei",
        "summary": "Run Nuclei",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "urls": { "type": "array", "items": {"type": "string"} }
                },
                "required": ["urls"]
              }
            }
          }
        },
        "responses": {
