                  "properties": {
                    "error": { "type": "string", "example": "URLs not provided" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/download/{filename}": {
      "get": {
        "operationId": "downloadFile",
        "summary": "Download file",
        "parameters": [
          {
            "name": "filename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File downloaded successfully",
            "content": {
              "text/csv": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "File not found"
          }
        }
      }
    },
    "/.well-known/openapi.json": {
      "get": {
        "operationId": "serveOpenapi",
        "summary": "Serve OpenAPI document",
        "responses": {
          "200": {
            "description": "OpenAPI document served",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  },
