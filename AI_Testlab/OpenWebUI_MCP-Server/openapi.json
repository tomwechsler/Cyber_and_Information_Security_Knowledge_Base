        },
        "required": ["urls"]
      },
      "downloadFileParameters": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" }
        },
        "required": ["filename"]
      },
      "serveOpenapiResponse": {
        "type": "object",
        "properties": {}
      }
    }
  }
