{
  "openapi": "3.0.0",
  "info": {
    "title": "MCP Recon API",
    "version": "1.1.0"
  },
  "paths": {
    "/run-subfinder": {
      "post": {
        "operationId": "runSubfinder",
        "summary": "Run Subfinder",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "domain": { "type": "string" }
                },
                "required": ["domain"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subdomains discovered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "results": { "type": "array", "items": { "type": "string" } },
                    "csv_download": { "type": "string", "example": "/download/subfinder_example.com.csv" }
                  },
                  "required": ["status", "results"]
                }
              }
            }
          },
          "400": {
            "description": "Domain not provided",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "Domain not provided" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/run-httpx-tech-detection": {
      "post": {
        "operationId": "runHttpxTechDetection",
        "summary": "Run HTTPX Tech Detection",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "domains": { "type": "array", "items": {"type": "string"} }
                },
                "required": ["domains"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tech detection results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "results": { "type": "array", "items": { "type": "string" } },
                    "csv_download": { "type": "string", "example": "/download/httpx_output.csv" }
                  },
                  "required": ["status", "results"]
                }
              }
            }
          },
          "400": {
            "description": "Domains not provided",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "Domains not provided" }
                  }
                }
              }
            }
          }
        }
      }
    },
